{
  "manifest_version": 3,
  "name": "FocusTube",
  "version": "1.0.0",
  "description": "Hide YouTube distractions and stay focused.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/content/youtube.js"],
      "run_at": "document_idle"
    }
  ]
}